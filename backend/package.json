{
  "name": "helpdesk-saas-backend",
  "version": "1.0.0",
  "description": "Enterprise SaaS Help Desk Backend using Node.js, TypeScript, DDD and Clean Architecture",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "start:prod": "NODE_ENV=production node dist/main.js",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build",
    "typecheck": "tsc --noEmit",
    "test": "echo \"Tests not configured yet\"",
    "test:watch": "echo \"Tests not configured yet\"",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "keywords": [
    "saas",
    "helpdesk",
    "ticket",
    "ddd",
    "clean-architecture",
    "typescript",
    "nodejs",
    "mongodb"
  ],
  "author": "João Jamba",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "axios": "^1.8.4",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.46.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.2",
    "nodemailer": "^7.0.2",
    "pino": "^9.6.0",
    "socket.io": "^4.8.3",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.0",
    "@types/nodemailer": "^6.4.17",
    "@types/uuid": "^10.0.0",
    "typescript": "^6.0.3",
    "ts-node-dev": "^2.0.0",
    "eslint": "^9.22.0",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  }
}